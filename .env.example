# Firebase Configuration
# Get these values from your Firebase Console (Project Settings)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google OAuth (Optional - for social sign-in)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# API Keys (Optional - for map/location services)
VITE_NOMINATIM_API_BASE=https://nominatim.openstreetmap.org
VITE_OVERPASS_API_BASE=https://overpass-api.de/api/interpreter

# Environment
VITE_ENV=development
