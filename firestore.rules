rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: is user authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function: is the current user
    function isUser(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      // Read: users can read their own doc, or public profiles
      allow read: if isUser(userId) || resource.data.get('isPublic', false) == true;

      // Write: only own data
      allow write: if isUser(userId);

      // Friends subcollection
      match /friends/{friendId} {
        allow read: if isUser(userId);
        allow write: if isUser(userId);
      }

      // Friend Requests subcollection
      match /friendRequests/{requestId} {
        allow read: if isUser(userId);
        allow write: if isAuth();
        allow delete: if isUser(userId) || request.auth.uid == resource.data.fromId;
      }
    }

    // Restaurants Collection
    match /restaurants/{restaurantId} {
      // Anyone can read
      allow read: if true;

      // Authenticated users can create
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;

      // Only creator can update/delete
      allow update, delete: if isAuth() && resource.data.createdBy == request.auth.uid;

      // Ratings subcollection
      match /ratings/{userId} {
        allow read: if true;
        allow write: if isUser(userId) && request.resource.data.uid == request.auth.uid;
      }
    }

    // Slots (Dining Slots) Collection
    match /slots/{slotId} {
      // Anyone can read
      allow read: if true;

      // Authenticated users can create
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;

      // Host can update/delete; any authenticated user can update only the participants array (for joining)
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']) &&
         request.auth.uid in request.resource.data.participants)
      );
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;

      // Messages subcollection
      match /messages/{messageId} {
        // Only participants can read
        allow read: if isAuth() && (
          request.auth.uid == get(/databases/$(database)/documents/slots/$(slotId)).data.createdBy ||
          request.auth.uid in get(/databases/$(database)/documents/slots/$(slotId)).data.get('participants', [])
        );

        // Authenticated participants can create messages
        allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      }
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isUser(resource.data.toUid);

      // Anyone authenticated can create
      allow create: if isAuth();

      // Only recipient can update (mark as read)
      allow update: if isUser(resource.data.toUid);
    }

    // Meta Collection (locations, config, etc)
    match /meta/{document=**} {
      // Anyone can read meta
      allow read: if true;

      // Authenticated users can write
      allow write: if isAuth();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
